      "benefits_en",
      "benefits_zh",
      "temperature_performance",
      "certifications",
      "tds_url",
      "catalog_url",
      "data_status",
      "sources",
      "last_verified"
    ],
    "dedupe_key": "manufacturer + product_code",
    "notes": "Schema bootstrapped 2026-07-03 from crawl task field mapping; the referenced 67-record seed file was not present in the repository.",
    "last_updated": "2026-07-03"
  },
